# Backend
HOWLHOUSE_ENV=dev
HOWLHOUSE_LOG_LEVEL=INFO
HOWLHOUSE_LOG_JSON=false
HOWLHOUSE_SECRET_KEY=dev-change-me
HOWLHOUSE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional DB (for docker compose, prefer /app/data mount)
HOWLHOUSE_DATABASE_URL=sqlite:///./data/howlhouse.db
HOWLHOUSE_DATA_DIR=./data
# For Postgres mode (M10), example:
# HOWLHOUSE_DATABASE_URL=postgresql://howlhouse:howlhouse@postgres:5432/howlhouse
HOWLHOUSE_POSTGRES_DB=howlhouse
HOWLHOUSE_POSTGRES_USER=howlhouse
HOWLHOUSE_POSTGRES_PASSWORD=howlhouse

# Artifact blob storage (M10)
HOWLHOUSE_BLOB_STORE=local
HOWLHOUSE_BLOB_BASE_DIR=./blob
HOWLHOUSE_S3_ENDPOINT=
HOWLHOUSE_S3_REGION=us-east-1
HOWLHOUSE_S3_BUCKET=
HOWLHOUSE_S3_ACCESS_KEY=
HOWLHOUSE_S3_SECRET_KEY=
HOWLHOUSE_S3_PREFIX=

# Worker queue (M11)
HOWLHOUSE_WORKER_ID=
HOWLHOUSE_WORKER_CONCURRENCY=1
HOWLHOUSE_WORKER_POLL_INTERVAL_MS=500
HOWLHOUSE_WORKER_LEASE_SECONDS=30
HOWLHOUSE_WORKER_STALE_AFTER_SECONDS=120
HOWLHOUSE_EMBEDDED_WORKER_ENABLED=true
HOWLHOUSE_WORKER_METRICS_ENABLED=false
HOWLHOUSE_WORKER_METRICS_PORT=9100

# LLM providers (used later)
HOWLHOUSE_OPENAI_API_KEY=
HOWLHOUSE_ANTHROPIC_API_KEY=

# Optional identity adapter (M7)
HOWLHOUSE_IDENTITY_ENABLED=false
HOWLHOUSE_IDENTITY_VERIFY_URL=
HOWLHOUSE_IDENTITY_TOKEN_HEADER=authorization
HOWLHOUSE_IDENTITY_RATE_LIMIT_WINDOW_S=60
HOWLHOUSE_IDENTITY_RATE_LIMIT_MAX_FAILURES=20
HOWLHOUSE_TRUST_PROXY_HEADERS=false
HOWLHOUSE_TRUSTED_PROXY_HOPS=1

# Access control + mutation quotas (M12)
HOWLHOUSE_AUTH_MODE=open
HOWLHOUSE_ADMIN_TOKENS=
HOWLHOUSE_ADMIN_TOKEN_HEADER=X-HowlHouse-Admin
HOWLHOUSE_QUOTA_AGENT_UPLOAD_MAX=0
HOWLHOUSE_QUOTA_AGENT_UPLOAD_WINDOW_S=0
HOWLHOUSE_QUOTA_MATCH_CREATE_MAX=0
HOWLHOUSE_QUOTA_MATCH_CREATE_WINDOW_S=0
HOWLHOUSE_QUOTA_MATCH_RUN_MAX=0
HOWLHOUSE_QUOTA_MATCH_RUN_WINDOW_S=0
HOWLHOUSE_QUOTA_TOURNAMENT_CREATE_MAX=0
HOWLHOUSE_QUOTA_TOURNAMENT_CREATE_WINDOW_S=0
HOWLHOUSE_QUOTA_TOURNAMENT_RUN_MAX=0
HOWLHOUSE_QUOTA_TOURNAMENT_RUN_WINDOW_S=0
HOWLHOUSE_QUOTA_RECAP_PUBLISH_MAX=0
HOWLHOUSE_QUOTA_RECAP_PUBLISH_WINDOW_S=0

# Moderation + retention (M13)
HOWLHOUSE_RETENTION_ENABLED=true
HOWLHOUSE_RETENTION_USAGE_EVENTS_DAYS=30
HOWLHOUSE_RETENTION_JOBS_DAYS=14
HOWLHOUSE_MAINTENANCE_INTERVAL_SECONDS=86400

# Optional recap distribution (M7)
HOWLHOUSE_DISTRIBUTION_ENABLED=false
HOWLHOUSE_DISTRIBUTION_POST_URL=

# Optional metrics + tracing (M8)
HOWLHOUSE_METRICS_ENABLED=false
HOWLHOUSE_METRICS_PATH=/metrics
HOWLHOUSE_TRACING_ENABLED=false
HOWLHOUSE_TRACING_SERVICE_NAME=howlhouse
HOWLHOUSE_TRACING_OTLP_ENDPOINT=
HOWLHOUSE_TRACING_SAMPLE_RATE=1.0
HOWLHOUSE_BACKUP_INTERVAL_SECONDS=86400

# Frontend (docker compose / browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production edge ingress (Traefik, M9)
HOWLHOUSE_DOMAIN=example.com
TRAEFIK_ACME_EMAIL=ops@example.com
# Use an htpasswd entry, e.g. `htpasswd -nbB metrics 'strong-password'`
TRAEFIK_METRICS_BASIC_AUTH=metrics:REPLACE_WITH_HTPASSWD_HASH

# Monitoring overlay
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
