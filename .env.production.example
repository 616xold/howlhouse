# Production baseline
HOWLHOUSE_ENV=production
HOWLHOUSE_LOG_LEVEL=INFO
HOWLHOUSE_LOG_JSON=true
HOWLHOUSE_SECRET_KEY=<set-me>
HOWLHOUSE_CORS_ORIGINS=https://<set-me>
HOWLHOUSE_ALLOWED_HOSTS=<set-me>

# Database and app storage
HOWLHOUSE_DATABASE_URL=postgresql://howlhouse:<set-me>@postgres:5432/howlhouse
HOWLHOUSE_DATA_DIR=./data
HOWLHOUSE_BLOB_STORE=local
HOWLHOUSE_BLOB_BASE_DIR=./blob
HOWLHOUSE_S3_ENDPOINT=
HOWLHOUSE_S3_REGION=us-east-1
HOWLHOUSE_S3_BUCKET=
HOWLHOUSE_S3_ACCESS_KEY=
HOWLHOUSE_S3_SECRET_KEY=
HOWLHOUSE_S3_PREFIX=

# Worker queue
HOWLHOUSE_WORKER_ID=
HOWLHOUSE_WORKER_CONCURRENCY=1
HOWLHOUSE_WORKER_POLL_INTERVAL_MS=500
HOWLHOUSE_WORKER_LEASE_SECONDS=30
HOWLHOUSE_WORKER_STALE_AFTER_SECONDS=120
HOWLHOUSE_EMBEDDED_WORKER_ENABLED=true
HOWLHOUSE_WORKER_METRICS_ENABLED=true
HOWLHOUSE_WORKER_METRICS_PORT=9100

# Agent sandbox
HOWLHOUSE_SANDBOX_DOCKER_IMAGE=python:3.11.11-slim-bookworm
HOWLHOUSE_SANDBOX_ALLOW_LOCAL_FALLBACK=false
HOWLHOUSE_ENABLE_UNSAFE_LOCAL_AGENT_RUNTIME=false
HOWLHOUSE_ALLOW_DEGRADED_START_WITHOUT_DOCKER=false
HOWLHOUSE_SANDBOX_ACT_TIMEOUT_MS=750
HOWLHOUSE_SANDBOX_MAX_OBSERVATION_BYTES=65536
HOWLHOUSE_SANDBOX_MAX_ACTION_BYTES=16384
HOWLHOUSE_SANDBOX_MAX_CALLS_PER_MATCH=1000
HOWLHOUSE_SANDBOX_CPU_LIMIT=0.5
HOWLHOUSE_SANDBOX_MEMORY_LIMIT=256m
HOWLHOUSE_SANDBOX_PIDS_LIMIT=128

# Identity, proxy, and access control
HOWLHOUSE_IDENTITY_ENABLED=true
HOWLHOUSE_IDENTITY_VERIFY_URL=https://<set-me>
HOWLHOUSE_IDENTITY_TOKEN_HEADER=authorization
HOWLHOUSE_IDENTITY_RATE_LIMIT_WINDOW_S=60
HOWLHOUSE_IDENTITY_RATE_LIMIT_MAX_FAILURES=20
HOWLHOUSE_TRUST_PROXY_HEADERS=true
HOWLHOUSE_TRUSTED_PROXY_HOPS=1
HOWLHOUSE_TRUSTED_PROXY_CIDRS=<set-me>
HOWLHOUSE_IDENTITY_VERIFY_HOST_ALLOWLIST=<set-me>
HOWLHOUSE_AUTH_MODE=verified
HOWLHOUSE_ADMIN_TOKENS=<set-me>
HOWLHOUSE_ADMIN_TOKEN_HEADER=X-HowlHouse-Admin
HOWLHOUSE_QUOTA_AGENT_UPLOAD_MAX=0
HOWLHOUSE_QUOTA_AGENT_UPLOAD_WINDOW_S=0
HOWLHOUSE_QUOTA_PREDICTION_MUTATION_MAX=0
HOWLHOUSE_QUOTA_PREDICTION_MUTATION_WINDOW_S=0
HOWLHOUSE_QUOTA_MATCH_CREATE_MAX=0
HOWLHOUSE_QUOTA_MATCH_CREATE_WINDOW_S=0
HOWLHOUSE_QUOTA_MATCH_RUN_MAX=0
HOWLHOUSE_QUOTA_MATCH_RUN_WINDOW_S=0
HOWLHOUSE_QUOTA_TOURNAMENT_CREATE_MAX=0
HOWLHOUSE_QUOTA_TOURNAMENT_CREATE_WINDOW_S=0
HOWLHOUSE_QUOTA_TOURNAMENT_RUN_MAX=0
HOWLHOUSE_QUOTA_TOURNAMENT_RUN_WINDOW_S=0
HOWLHOUSE_QUOTA_RECAP_PUBLISH_MAX=0
HOWLHOUSE_QUOTA_RECAP_PUBLISH_WINDOW_S=0

# Retention, metrics, and tracing
HOWLHOUSE_RETENTION_ENABLED=true
HOWLHOUSE_RETENTION_USAGE_EVENTS_DAYS=30
HOWLHOUSE_RETENTION_JOBS_DAYS=14
HOWLHOUSE_MAINTENANCE_INTERVAL_SECONDS=86400
HOWLHOUSE_METRICS_ENABLED=true
HOWLHOUSE_METRICS_PATH=/metrics
HOWLHOUSE_TRACING_ENABLED=false
HOWLHOUSE_TRACING_SERVICE_NAME=howlhouse
HOWLHOUSE_TRACING_OTLP_ENDPOINT=
HOWLHOUSE_TRACING_SAMPLE_RATE=1.0

# Optional outbound recap distribution
HOWLHOUSE_DISTRIBUTION_ENABLED=false
HOWLHOUSE_DISTRIBUTION_POST_URL=
HOWLHOUSE_DISTRIBUTION_POST_HOST_ALLOWLIST=

# Frontend
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_ENABLE_UNSAFE_LOCAL_AGENT_RUNTIME=false

# Edge ingress (Traefik)
HOWLHOUSE_DOMAIN=<set-me>
TRAEFIK_ACME_EMAIL=<set-me>
TRAEFIK_METRICS_BASIC_AUTH=<set-me>

# Monitoring overlay
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<set-me>
