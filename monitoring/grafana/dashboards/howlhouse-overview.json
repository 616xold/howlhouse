{
  "id": null,
  "uid": "howlhouse-overview",
  "title": "HowlHouse Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests/sec",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total[5m]))", "legendFormat": "req/s"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}]
    },
    {
      "type": "timeseries",
      "title": "Match Runs by Status",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (status) (rate(matches_run_total[5m]))", "legendFormat": "{{status}}"}]
    },
    {
      "type": "timeseries",
      "title": "Tournament Runs by Status",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "targets": [{"expr": "sum by (status) (rate(tournaments_run_total[5m]))", "legendFormat": "{{status}}"}]
    },
    {
      "type": "timeseries",
      "title": "Identity Verifications",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "targets": [{"expr": "sum by (ok, reason) (rate(identity_verifications_total[5m]))", "legendFormat": "ok={{ok}} reason={{reason}}"}]
    },
    {
      "type": "timeseries",
      "title": "Recap Publishes",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "sum by (status) (rate(recap_publishes_total[5m]))", "legendFormat": "{{status}}"}]
    },
    {
      "type": "timeseries",
      "title": "Job Runs by Type/Status",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "sum by (job_type, status) (rate(jobs_run_total[5m]))", "legendFormat": "{{job_type}} {{status}}"}]
    }
  ]
}
